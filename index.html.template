<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="light dark">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <svg class="icon-sprite" aria-hidden="true" focusable="false">
        <symbol id="file-icon-file" viewBox="0 0 16 16" fill="none" stroke="currentColor"
            stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3.5 1.5h6l3 3v10h-9z"/>
            <path d="M9.5 1.5v3h3"/>
        </symbol>
        <symbol id="file-icon-folder" viewBox="0 0 16 16" fill="none" stroke="currentColor"
            stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
            <path d="M1.5 3.5h5l1.5 2h6.5v8h-13z"/>
            <path d="M1.5 5.5h13"/>
        </symbol>
        <symbol id="file-icon-text" viewBox="0 0 16 16" fill="none" stroke="currentColor"
            stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3.5 1.5h6l3 3v10h-9z"/>
            <path d="M9.5 1.5v3h3M5.5 7h5M8 7v4.5M6.5 11.5h3"/>
        </symbol>
        <symbol id="file-icon-image" viewBox="0 0 16 16" fill="none" stroke="currentColor"
            stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3.5 1.5h6l3 3v10h-9z"/>
            <path d="M9.5 1.5v3h3M5 12l2.25-2.5 1.5 1.5 1.25-1.25 1.25 2.25"/>
            <circle cx="6.25" cy="6.75" r=".75" fill="currentColor" stroke="none"/>
        </symbol>
        <symbol id="file-icon-video" viewBox="0 0 16 16" fill="none" stroke="currentColor"
            stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1.5" y="3.5" width="13" height="9" rx="1"/>
            <path d="M6.5 6l4 2-4 2z" fill="currentColor" stroke="none"/>
        </symbol>
        <symbol id="file-icon-audio" viewBox="0 0 16 16" fill="none" stroke="currentColor"
            stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6.5 12V4.5l6-1.5v7"/>
            <ellipse cx="4.5" cy="12" rx="2" ry="1.5"/>
            <ellipse cx="10.5" cy="10" rx="2" ry="1.5"/>
        </symbol>
        <symbol id="file-icon-document" viewBox="0 0 16 16" fill="none" stroke="currentColor"
            stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3.5 1.5h6l3 3v10h-9z"/>
            <path d="M9.5 1.5v3h3M5.5 7h5M5.5 9.5h5M5.5 12h3.5"/>
        </symbol>
        <symbol id="action-icon-archive" viewBox="0 0 16 16" fill="none" stroke="currentColor"
            stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
            <path d="M1.5 3.5h5l1.5 2h6.5v8h-13zM1.5 5.5h13"/>
            <path d="M8 7v4M6.25 9.5 8 11.25 9.75 9.5"/>
        </symbol>
        <symbol id="action-icon-qr" viewBox="0 0 16 16">
            <path fill="currentColor" fill-rule="evenodd" d="M0 0h7v7H0zm1 1v5h5V1zm1 1h3v3H2zM9 0h7v7H9zm1 1v5h5V1zm1 1h3v3h-3zM0 9h7v7H0zm1 1v5h5v-5zm1 1h3v3H2zM9 9h2v2H9zm4 0h3v3h-3zm-4 4h3v3H9zm5 1h2v2h-2z"/>
        </symbol>
    </svg>
    <div class="split left">
        <span class="listing-title"><b>Files:</b> <a class="file-action archive-download" href="{{.ArchiveURL}}"
            title="download this directory as a compressed Unix archive" aria-label="download this directory as a compressed Unix archive"><svg
            viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" focusable="false"><use href="#action-icon-archive"/></svg></a></span><br>
        <p id="archiveStatus" class="archive-status" role="status" aria-live="polite" hidden></p>
        {{range .Files}}<span class="file-name"><svg class="file-type-icon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" focusable="false"><use href="#file-icon-{{.Icon}}"/></svg>{{if .Href}}<a href="{{.Href}}">{{.Name}}</a>{{else}}{{.Name}}{{end}}</span>{{if .ArchiveHref}} <a class="file-action archive-download" href="{{.ArchiveHref}}" title="download directory as a compressed Unix archive" aria-label="download {{.Name}} as a compressed Unix archive"><svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" focusable="false"><use href="#action-icon-archive"/></svg></a>{{end}}{{range .Actions}} <a class="{{.CSSClass}}" data-transport-id="{{.BackendID}}" href="{{.Href}}" title="{{.Title}}" aria-label="{{.AccessibleName}}"><svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true"><use href="#{{.IconID}}"/></svg></a>{{end}}{{if .Note}} <small>({{.Note}})</small>{{end}}<br>
        {{end}}
    </div>
    <div class="split right">
        {{if .UploadURL}}
        <form id="uploadForm" method="post" action="{{.UploadURL}}" enctype="multipart/form-data">
            <div>
                <label for="file">Choose file to upload</label>
                <input type="file" id="file" name="file" multiple>
            </div>
            <div>
                <button type="submit">Upload</button>
            </div>
            <p id="uploadStatus" role="status" aria-live="polite"></p>
        </form>
        {{end}}
        {{if .ShowQR}}<img src="{{.QRURL}}" alt="this page as QR code" title="scan to open this page on another device"
            style="position: fixed; bottom: 8px; right: 8px; width: 128px; height: 128px;">{{end}}
    </div>
    <button class="camera-open" type="button" data-https-url="{{.HTTPSURL}}"
        data-scanner-id="{{.Scanner.ID}}" data-worker-url="{{.Scanner.WorkerURL}}"
        data-idle-prompt="{{.Scanner.IdlePrompt}}" data-transfer-label="{{.Scanner.TransferLabel}}"
        title="receive a file by scanning a {{.Scanner.TransferLabel}} stream with this device's camera"
        aria-label="open {{.Scanner.TransferLabel}} scanner"><svg
        viewBox="0 0 16 16" width="48" height="48" aria-hidden="true"><path fill="currentColor" d="M1 1h4v2H3v2H1zM11 1h4v4h-2V3h-2zM1 11h2v2h2v2H1zM11 15v-2h2v-2h2v4z"/><circle cx="8" cy="8" r="2.5" fill="currentColor"/></svg></button>
    <dialog class="qr-dialog">
        <img alt="QR codes">
        <p></p>
    </dialog>
    <dialog class="camera-dialog" aria-labelledby="camera-title">
        <div class="camera-shell">
            <header class="camera-header">
                <strong id="camera-title">{{.Scanner.DialogTitle}}</strong>
                <button class="close" type="button" title="close" aria-label="close scanner">&times;</button>
            </header>
            <div class="camera-stage">
                <video playsinline webkit-playsinline muted aria-label="camera preview"></video>
                <svg class="scan-guide" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
                    <path d="M20 6H6v14M80 6h14v14M94 80v14H80M20 94H6V80"/>
                </svg>
                <div class="camera-status">
                    <p class="progress" role="status" aria-live="polite"></p>
                    <progress class="frame-progress" max="1" value="0" hidden
                        aria-label="received {{.Scanner.TransferLabel}} stream frames"></progress>
                </div>
            </div>
            <div class="camera-actions" hidden>
                <button class="save" type="button" hidden>save received file</button>
                <button class="restart" type="button" hidden>restart decoder</button>
            </div>
        </div>
    </dialog>
    <script>
    {{if .BrowserLogging}}
    function qlog(message) {
        const text = String(message);
        console.debug('[serve]', text);
        try {
            fetch('/log', {
                method: 'POST',
                headers: { 'Content-Type': 'text/plain; charset=utf-8' },
                body: text,
                keepalive: true,
            }).catch(() => {});
        } catch {}
    }
    window.addEventListener('error', e => {
        qlog('window error ' + e.message);
    });
    window.addEventListener('unhandledrejection', e => {
        const reason = e.reason instanceof Error
            ? e.reason.name + ': ' + e.reason.message
            : String(e.reason);
        qlog('unhandled rejection ' + reason);
    });
    qlog('page ready secure=' + window.isSecureContext + ' protocol=' + location.protocol);
    {{else}}
    function qlog() {}
    {{end}}

    {{if .UploadURL}}
    const uploadForm = document.querySelector('#uploadForm');
    const uploadInput = uploadForm.querySelector('input[type="file"]');
    const uploadButton = uploadForm.querySelector('button[type="submit"]');
    const uploadStatus = uploadForm.querySelector('#uploadStatus');
    let uploadRequest = null;
    function finishUpload(request) {
        if (uploadRequest !== request) return;
        uploadRequest = null;
        uploadInput.disabled = false;
        uploadButton.disabled = false;
        uploadForm.removeAttribute('aria-busy');
    }
    uploadForm.addEventListener('submit', e => {
        e.preventDefault();
        if (uploadRequest) return;
        const fileCount = uploadInput.files.length;
        if (!fileCount) {
            uploadStatus.textContent = 'choose at least one file';
            return;
        }

        const request = new XMLHttpRequest();
        const data = new FormData(uploadForm);
        uploadRequest = request;
        uploadInput.disabled = true;
        uploadButton.disabled = true;
        uploadForm.setAttribute('aria-busy', 'true');
        uploadStatus.textContent = 'uploading';
        request.upload.addEventListener('progress', event => {
            if (!event.lengthComputable) return;
            const percent = Math.min(100, Math.round(event.loaded * 100 / event.total));
            uploadStatus.textContent = 'uploading ' + percent + '%';
        });
        request.addEventListener('load', () => {
            if (request.status >= 200 && request.status < 300) {
                uploadStatus.textContent = fileCount === 1
                    ? 'upload complete'
                    : fileCount + ' uploads complete';
                uploadInput.value = '';
            } else {
                const detail = request.responseText.trim();
                uploadStatus.textContent = detail || 'upload failed (' + request.status + ')';
            }
            finishUpload(request);
        });
        request.addEventListener('error', () => {
            uploadStatus.textContent = 'upload failed: network error';
            finishUpload(request);
        });
        request.addEventListener('abort', () => {
            uploadStatus.textContent = 'upload cancelled';
            finishUpload(request);
        });
        request.open('POST', uploadForm.action);
        request.send(data);
    });
    {{end}}

    const archiveStatus = document.querySelector('#archiveStatus');
    function newArchiveToken() {
        const bytes = new Uint8Array(16);
        crypto.getRandomValues(bytes);
        return Array.from(bytes, byte => byte.toString(16).padStart(2, '0')).join('');
    }
    function showArchiveStatus(message) {
        archiveStatus.hidden = false;
        archiveStatus.textContent = message;
    }
    async function pollArchiveStatus(token, name, missingAttempts = 0) {
        let response;
        try {
            response = await fetch('/.serve/archive-status?status=' + encodeURIComponent(token), {
                cache: 'no-store',
            });
        } catch {
            showArchiveStatus('waiting for archive status');
            setTimeout(() => pollArchiveStatus(token, name, missingAttempts), 1000);
            return;
        }
        if (response.status === 404) {
            if (missingAttempts < 20) {
                setTimeout(() => pollArchiveStatus(token, name, missingAttempts + 1), 500);
            } else {
                showArchiveStatus('archive status unavailable for ' + name);
            }
            return;
        }
        if (response.status === 202) {
            showArchiveStatus('archiving ' + name);
            setTimeout(() => pollArchiveStatus(token, name), 750);
            return;
        }
        if (!response.ok) {
            showArchiveStatus('archive status failed (' + response.status + ')');
            return;
        }
        const result = await response.json();
        const filename = result.filename || name;
        if (result.error) {
            const message = 'archive failed: ' + result.error;
            showArchiveStatus(message);
            alert(message);
        } else if (result.warnings) {
            const message = filename + ' completed with ' + result.warnings + ' warning' + (result.warnings === 1 ? '' : 's');
            showArchiveStatus(message);
            alert(message + '; see the error report inside the archive');
        } else {
            showArchiveStatus(filename + ' complete');
        }
    }
    for (const link of document.querySelectorAll('.archive-download')) {
        link.addEventListener('click', e => {
            e.preventDefault();
            const token = newArchiveToken();
            const target = new URL(link.href);
            target.searchParams.set('status', token);
            const download = document.createElement('a');
            download.href = target;
            download.download = '';
            document.body.append(download);
            download.click();
            download.remove();
            const name = link.getAttribute('aria-label').replace(/^download /, '').replace(/ as a compressed Unix archive$/, '');
            showArchiveStatus('starting archive for ' + name);
            pollArchiveStatus(token, name);
        });
    }

    const qrDialog = document.querySelector('.qr-dialog');
    const stream = qrDialog.querySelector('img');
    const caption = qrDialog.querySelector('p');
    for (const link of document.querySelectorAll('.qr-transfer')) {
        link.addEventListener('click', e => {
            e.preventDefault();
            stream.src = link.getAttribute('href');
            caption.textContent = decodeURIComponent(link.pathname.split('/').pop());
            qrDialog.showModal();
        });
    }
    /* click on the backdrop (the dialog element itself) closes; Esc is built in */
    qrDialog.addEventListener('click', e => { if (e.target === qrDialog) qrDialog.close(); });
    /* swap in a blank image on close so the browser aborts the stream */
    qrDialog.addEventListener('close', () => {
        stream.src = 'data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==';
    });

    /* camera scanning: frames are decoded in the browser by the
       selected wasm scanner running in a worker; the file is saved on
       this device. Scanning continues after a file completes so the
       next stream is picked up without reopening. */
    const cameraButton = document.querySelector('.camera-open');
    const scannerBackend = Object.freeze({
        id: cameraButton.dataset.scannerId,
        workerURL: cameraButton.dataset.workerUrl,
        idlePrompt: cameraButton.dataset.idlePrompt,
        transferLabel: cameraButton.dataset.transferLabel,
    });
    const camDialog = document.querySelector('.camera-dialog');
    const video = camDialog.querySelector('video');
    const camProgress = camDialog.querySelector('.progress');
    const frameProgress = camDialog.querySelector('.frame-progress');
    const cameraActions = camDialog.querySelector('.camera-actions');
    const saveButton = camDialog.querySelector('.save');
    const restartButton = camDialog.querySelector('.restart');
    video.disablePictureInPicture = true; /* no popout into native PiP */
    let scanTimer, camStream, scanWorker, scanBusy, scanning, openingCamera;
    let cameraGeneration = 0;

    function resetFrameProgress() {
        frameProgress.value = 0;
        frameProgress.max = 1;
        frameProgress.hidden = true;
    }
    function stopDecoder() {
        const worker = scanWorker;
        scanWorker = null;
        scanBusy = false;
        if (worker) worker.terminate();
    }
    function renderCameraActions() {
        cameraActions.hidden = saveButton.hidden && restartButton.hidden;
    }
    function decoderFailed(message) {
        qlog('scanner stopped ' + message);
        scanning = false;
        stopDecoder();
        resetFrameProgress();
        camProgress.textContent = message;
        restartButton.hidden = false;
        renderCameraActions();
    }
    function loadDecoder() {
        if (scanWorker) return true;
        let worker;
        try {
            worker = new Worker(scannerBackend.workerURL);
        } catch (err) {
            decoderFailed('decoder could not start: ' + err.message);
            return false;
        }
        scanWorker = worker;
        scanBusy = false;
        restartButton.hidden = true;
        renderCameraActions();
        qlog('scanner worker created');
        worker.addEventListener('message', e => {
            if (worker !== scanWorker) return;
            scanBusy = false;
            scanResult(e.data);
        });
        worker.addEventListener('error', e => {
            if (worker !== scanWorker) return;
            decoderFailed('decoder stopped: ' + (e.message || 'worker error'));
        });
        worker.addEventListener('messageerror', () => {
            if (worker !== scanWorker) return;
            decoderFailed('decoder returned an unreadable result');
        });
        return true;
    }
    function restartDecoder() {
        stopDecoder();
        camProgress.textContent = 'restarting decoder';
        if (!loadDecoder()) return;
        scanning = Boolean(camDialog.open && camStream);
        camProgress.textContent = scannerBackend.idlePrompt;
    }
    function scanResult(result) {
        if (!result) return;
        if (result.error) {
            qlog('scanner error ' + result.error);
            if (result.recoverable) {
                resetFrameProgress();
                camProgress.textContent = 'stream reset: ' + result.error;
                return;
            }
            decoderFailed(result.error);
            return;
        }
        /* the just-completed stream is still in view - ignore it (the
           receiver compares only against the last stream id) */
        if (result.sameAsLast) return;
        if (result.done) {
            qlog('scanner complete file=' + result.fileID + ' bytes=' + result.data.byteLength);
            frameProgress.hidden = false;
            frameProgress.max = Math.max(1, Number(result.total) || 1);
            frameProgress.value = frameProgress.max;
            camProgress.textContent = 'received ' + result.name;
            setReceived(result.name, result.data);
        } else {
            const total = Math.max(1, Number(result.total) || 1);
            const have = Math.min(total, Math.max(0, Number(result.have) || 0));
            frameProgress.hidden = false;
            frameProgress.max = total;
            frameProgress.value = have;
            camProgress.textContent = 'receiving ' + have + ' of ' + total + ' frames';
        }
    }

    /* The last received file is kept in memory and re-shown whenever
       the camera overlay is opened, until ten minutes pass. The save
       sheet fires automatically on completion; iOS only allows
       navigator.share inside a fresh user gesture, so if a long
       multi-part scan has outlasted that activation the save button
       or a tap on the preview re-fires it. */
    const RECEIVED_TTL = 10 * 60 * 1000;
    let received, receivedTimer;
    function setReceived(name, data) {
        received = { name, data, time: Date.now() };
        clearTimeout(receivedTimer);
        receivedTimer = setTimeout(clearReceived, RECEIVED_TTL);
        renderReceived();
        saveReceived(); /* open the save sheet right away */
    }
    function clearReceived() {
        received = null;
        renderReceived();
    }
    function saveReceived() {
        if (!received) return;
        const file = new File([received.data], received.name, { type: 'application/octet-stream' });
        if (navigator.canShare && navigator.canShare({ files: [file] })) {
            navigator.share({ files: [file] })
                .catch(err => {
                    if (err.name !== 'AbortError' && err.name !== 'NotAllowedError') {
                        qlog('save share failed ' + err.name + ': ' + err.message);
                        camProgress.textContent = 'save failed: ' + err.message;
                    } else if (err.name === 'NotAllowedError') {
                        qlog('automatic save needs a fresh user gesture');
                    }
                });
        } else {
            const dl = document.createElement('a');
            const objectURL = URL.createObjectURL(file);
            dl.href = objectURL;
            dl.download = received.name;
            dl.click();
            setTimeout(() => URL.revokeObjectURL(objectURL), 1000);
        }
    }
    function renderReceived() {
        if (received && Date.now() - received.time > RECEIVED_TTL) received = null;
        saveButton.hidden = !received;
        saveButton.textContent = received ? 'save ' + received.name : 'save received file';
        renderCameraActions();
    }
    async function openCamera() {
        if (openingCamera || camDialog.open) return;
        qlog('camera open requested');
        if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
            /* camera access needs a secure context */
            if (location.protocol !== 'https:') {
                qlog('camera unavailable on insecure page; redirecting to https');
                location.assign(cameraButton.dataset.httpsUrl);
                return;
            }
            qlog('camera API unavailable');
            camDialog.showModal();
            camProgress.textContent = 'camera API unavailable in this browser';
            return;
        }
        const generation = ++cameraGeneration;
        openingCamera = true;
        cameraButton.disabled = true;
        resetFrameProgress();
        restartButton.hidden = true;
        renderCameraActions();
        camProgress.textContent = 'requesting camera permission';
        renderReceived();
        camDialog.showModal();
        loadDecoder();
        try {
            camStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
        } catch (err) {
            qlog('camera request failed ' + err.name + ': ' + err.message);
            camProgress.textContent = 'camera unavailable: ' + err.message;
            stopDecoder();
            openingCamera = false;
            cameraButton.disabled = false;
            return;
        }
        if (generation !== cameraGeneration || !camDialog.open) {
            for (const track of camStream.getTracks()) track.stop();
            camStream = null;
            return;
        }
        scanBusy = false;
        camProgress.textContent = scannerBackend.idlePrompt;
        video.srcObject = camStream;
        try {
            await video.play();
            qlog('camera preview started width=' + video.videoWidth + ' height=' + video.videoHeight);
        } catch (err) {
            qlog('camera preview failed ' + err.name + ': ' + err.message);
            camProgress.textContent = 'camera preview failed: ' + err.message;
            stopDecoder();
            for (const track of camStream.getTracks()) track.stop();
            camStream = null;
            video.srcObject = null;
            openingCamera = false;
            cameraButton.disabled = false;
            return;
        }
        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d', { willReadFrequently: true });
        if (!ctx) {
            camProgress.textContent = 'camera frame processing is unavailable';
            stopDecoder();
            for (const track of camStream.getTracks()) track.stop();
            camStream = null;
            video.srcObject = null;
            openingCamera = false;
            cameraButton.disabled = false;
            return;
        }
        scanning = true;
        openingCamera = false;
        cameraButton.disabled = false;
        clearInterval(scanTimer);
        scanTimer = setInterval(() => {
            /* one frame in flight at a time: the worker's decode
               speed sets the pace, the preview never freezes */
            if (!scanning || scanBusy || !video.videoWidth) return;
            /* downscale: full camera resolution costs decode time
               without helping screen-displayed codes */
            let img;
            try {
                const scale = Math.min(1, 1024 / video.videoWidth);
                canvas.width = Math.round(video.videoWidth * scale);
                canvas.height = Math.round(video.videoHeight * scale);
                ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
                img = ctx.getImageData(0, 0, canvas.width, canvas.height);
            } catch (err) {
                decoderFailed('camera frame failed: ' + err.message);
                return;
            }
            if (!scanWorker) return;
            scanBusy = true;
            try {
                scanWorker.postMessage(
                    { width: img.width, height: img.height, buffer: img.data.buffer },
                    [img.data.buffer]);
            } catch (err) {
                decoderFailed('decoder stopped: ' + err.message);
            }
        }, 100);
    }
    cameraButton.addEventListener('click', openCamera);
    /* explicit close only - no backdrop-tap close, which stray
       touches kept triggering while holding the phone to scan */
    camDialog.querySelector('.close').addEventListener('click', () => camDialog.close());
    saveButton.addEventListener('click', saveReceived);
    restartButton.addEventListener('click', restartDecoder);
    /* a tap on the preview re-fires the save sheet for the pending
       file: on iOS the auto-attempt at completion may have lacked a
       fresh gesture, and this tap supplies one */
    video.addEventListener('click', saveReceived);
    camDialog.addEventListener('close', () => {
        qlog('camera closed');
        cameraGeneration++;
        openingCamera = false;
        cameraButton.disabled = false;
        scanning = false;
        clearInterval(scanTimer);
        stopDecoder();
        restartButton.hidden = true;
        renderCameraActions();
        resetFrameProgress();
        video.pause();
        if (camStream) for (const t of camStream.getTracks()) t.stop();
        camStream = null;
        video.srcObject = null;
    });
    </script>
</body>
</html>
